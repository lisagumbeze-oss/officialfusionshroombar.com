// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ManualPaymentMethod {
  id          String   @id @default(cuid())
  name        String   // e.g., "CashApp", "Zelle", "Bitcoin"
  details     String   // e.g., "$FusionBars", "info@fusion.com", "bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh"
  instructions String? // Optional instructions for checkout
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String
  shippingMethod  String?
  shippingPrice   Float    @default(0)
  totalAmount     Float
  status          String   @default("PENDING") // PENDING, PROCESSING, SHIPPED, COMPLETED, CANCELLED
  
  trackingNumber  String?
  trackingUrl     String?
  notes           String?  // Internal admin notes
  customerNote    String?  // Note from customer during checkout
  
  paymentMethodId String
  paymentMethod   ManualPaymentMethod @relation(fields: [paymentMethodId], references: [id])
  
  items           LineItem[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LineItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?  // Can now optionally link to dynamic Product
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  quantity    Int
  price       Float    // Price at the time of purchase
}

model Product {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  price        Float
  regularPrice Float?
  category     String
  description  String
  image        String
  weight       String?
  effects      String?    // Store as JSON string stringified array
  ingredients  String?    // Store as JSON string stringified array
  gallery      String?    // Store as JSON stringified array of URLs (up to 5)
  dosage       String?
  
  // Stock Management
  sku             String?  @unique
  stock           Int      @default(0)
  lowStockThreshold Int    @default(5)
  manageStock     Boolean  @default(true)
  
  isActive     Boolean    @default(true)
  
  // SEO Fields
  seoTitle     String?
  seoDescription String?
  targetKeyword String?
  seoKeywords  String?    // Comma-separated
  imageAlt     String?
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  variants     ProductVariant[]
  lineItems    LineItem[]
  reviews      Review[]
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  name            String   // e.g. "Size: M", "Flavor: Raspberry"
  sku             String?  @unique
  price           Float?   // Override price if needed
  stock           Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountType    String   // "PERCENTAGE" or "FIXED"
  discountValue   Float
  minOrderAmount  Float    @default(0)
  expiryDate      DateTime?
  usageLimit      Int?
  usageCount      Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StoreSettings {
  id                String   @id @default("global")
  
  // General
  storeName         String   @default("Fusion Shroom Bars")
  tagline           String?
  storeDescription  String?
  logoUrl           String?
  faviconUrl        String?
  
  // Contact
  email             String?
  phone             String?
  address           String?
  
  // SEO
  siteTitleTemplate String   @default("%page_title% | %site_name%")
  defaultMetaDescription String?
  defaultOgImage    String?
  robotsTxt         String?  @default("User-agent: *\nAllow: /")
  googleAnalyticsId String?
  
  // Localization
  currencyCode      String   @default("USD")
  currencySymbol    String   @default("$")
  
  // System
  maintenanceMode   Boolean  @default(false)
  maintenanceMessage String? @default("Site is currently undergoing maintenance. Please check back soon!")
  
  updatedAt         DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  name      String
  content   String
  rating    Int      @default(5)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingSetting {
  id                String   @id @default(cuid())
  type              String   // "LOCAL" or "INTERNATIONAL"
  category1Name     String   @default("Standard")
  category1Price    Float    @default(0)
  category2Name     String   @default("Express")
  category2Price    Float    @default(0)
  updatedAt         DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String   @default("") // HTML content
  image         String?  // Featured image URL
  
  status        String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  author        String   @default("Admin")
  category      String   @default("Uncategorized")
  tags          String   @default("[]")    // JSON stringified array
  isPublic      Boolean  @default(true)
  allowComments Boolean  @default(true)
  
  // SEO
  seoTitle      String?
  seoDescription String?
  targetKeyword String?
  seoKeywords   String?  // Comma-separated
  imageAlt      String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  comments      Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  name       String
  content    String
  blogPostId String
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model PageMetadata {
  id            String   @id @default(cuid())
  path          String   @unique // e.g., "/", "/about", "/shop"
  title         String?
  description   String?
  targetKeyword String?
  seoKeywords   String?  // Comma-separated
  imageAlt      String?
  updatedAt     DateTime @updatedAt
}

model MediaAsset {
  id               String   @id @default(cuid())
  filename         String
  originalFilename String
  mimeType         String
  size             Int      // bytes
  url              String
  altText          String?
  caption          String?
  uploadedBy       String   @default("Admin")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
